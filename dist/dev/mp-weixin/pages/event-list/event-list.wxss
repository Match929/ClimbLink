
.container.data-v-58fd2ed6 {
  min-height: 100vh;
  background-color: #f5f9f5;
}

/* 顶部导航 */
.header.data-v-58fd2ed6 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
}
.back-btn.data-v-58fd2ed6,
.add-btn.data-v-58fd2ed6 {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon.data-v-58fd2ed6,
.add-icon.data-v-58fd2ed6 {
  font-size: 40rpx;
  color: #333;
}
.header-title.data-v-58fd2ed6 {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.content.data-v-58fd2ed6 {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

/* 筛选标签 */
.filter-scroll.data-v-58fd2ed6 {
  margin-bottom: 30rpx;
}
.filter-list.data-v-58fd2ed6 {
  display: flex;
  white-space: nowrap;
  gap: 20rpx;
}
.filter-item.data-v-58fd2ed6 {
  display: inline-block;
  padding: 16rpx 30rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  border: 2rpx solid transparent;
}
.filter-item.active.data-v-58fd2ed6 {
  background-color: #e8f5e0;
  border-color: #7eb662;
}
.filter-item text.data-v-58fd2ed6 {
  font-size: 26rpx;
  color: #666;
}
.filter-item.active text.data-v-58fd2ed6 {
  color: #5a8a3f;
  font-weight: 500;
}

/* 活动列表 */
.events-list.data-v-58fd2ed6 {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.event-card.data-v-58fd2ed6 {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}
.event-image.data-v-58fd2ed6 {
  width: 100%;
  height: 300rpx;
}
.event-info.data-v-58fd2ed6 {
  padding: 24rpx;
}
.event-tag.data-v-58fd2ed6 {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: #e8f5e0;
  color: #5a8a3f;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.event-title.data-v-58fd2ed6 {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.event-meta.data-v-58fd2ed6 {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
}
.meta-item.data-v-58fd2ed6 {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.meta-item text.data-v-58fd2ed6:first-child {
  font-size: 24rpx;
}
.meta-item text.data-v-58fd2ed6:last-child {
  font-size: 24rpx;
  color: #666;
}
.event-footer.data-v-58fd2ed6 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.attendees.data-v-58fd2ed6 {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.attendee-avatar.data-v-58fd2ed6 {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  margin-left: -16rpx;
}
.attendee-avatar.data-v-58fd2ed6:first-child {
  margin-left: 0;
}
.attendees-count.data-v-58fd2ed6 {
  font-size: 22rpx;
  color: #999;
}
.event-level.data-v-58fd2ed6 {
  padding: 8rpx 16rpx;
  background-color: #f5f9f5;
  border-radius: 20rpx;
}
.event-level text.data-v-58fd2ed6 {
  font-size: 22rpx;
  color: #666;
}
.safe-area-bottom.data-v-58fd2ed6 {
  height: env(safe-area-inset-bottom);
}
