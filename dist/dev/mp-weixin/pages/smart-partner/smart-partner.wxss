}
.venue-icon.data-v-d1dfe639 {
  font-size: 16px;
}
.venue-name.data-v-d1dfe639 {
  font-size: 14px;
  font-weight: 500;
  color: white;
}
.search-box.data-v-d1dfe639 {
  position: relative;
  background: white;
  border-radius: 12px;
  padding: 12px 16px;
  padding-left: 44px;
  display: flex;
  align-items: center;
}
.search-icon.data-v-d1dfe639 {
  position: absolute;
  left: 16px;
  font-size: 20px;
  color: #9ca3af;
}
.search-input.data-v-d1dfe639 {
  width: 100%;
