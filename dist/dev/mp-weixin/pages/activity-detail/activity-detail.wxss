
.container.data-v-47f02b22 {
  min-height: 100vh;
  background-color: #f5f9f5;
  padding-bottom: 200rpx;
}

/* 图片区域 */
.image-section.data-v-47f02b22 {
  position: relative;
  width: 100%;
  height: 480rpx;
}
.activity-image.data-v-47f02b22 {
  width: 100%;
  height: 100%;
}
.back-btn.data-v-47f02b22 {
  position: absolute;
  top: 40rpx;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.back-icon.data-v-47f02b22 {
  font-size: 36rpx;
  color: #333;
}
.favorite-btn.data-v-47f02b22 {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.favorite-icon.data-v-47f02b22 {
  font-size: 36rpx;
}

/* 信息区域 */
.info-section.data-v-47f02b22 {
  background-color: #ffffff;
  padding: 40rpx 30rpx;
  margin-top: -30rpx;
  border-radius: 30rpx 30rpx 0 0;
  position: relative;
  z-index: 5;
}
.activity-header.data-v-47f02b22 {
  margin-bottom: 30rpx;
}
.activity-title.data-v-47f02b22 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.activity-tags.data-v-47f02b22 {
  display: flex;
  gap: 12rpx;
}
.activity-tag.data-v-47f02b22 {
  padding: 8rpx 20rpx;
  background-color: #d4e7c5;
  color: #5a8a3f;
  border-radius: 30rpx;
  font-size: 22rpx;
}

/* 主办方 */
.organizer-section.data-v-47f02b22 {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #eee;
}
.organizer-avatar.data-v-47f02b22 {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.organizer-info.data-v-47f02b22 {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.organizer-name.data-v-47f02b22 {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}
.organizer-label.data-v-47f02b22 {
  font-size: 22rpx;
  color: #999;
}

/* 详情列表 */
.detail-list.data-v-47f02b22 {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.detail-item.data-v-47f02b22 {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.detail-icon-wrap.data-v-47f02b22 {
  width: 72rpx;
  height: 72rpx;
  background-color: #f0f7ec;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.detail-icon.data-v-47f02b22 {
  font-size: 32rpx;
}
.detail-content.data-v-47f02b22 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.detail-label.data-v-47f02b22 {
  font-size: 22rpx;
  color: #999;
}
.detail-value.data-v-47f02b22 {
  font-size: 26rpx;
  color: #333;
}
.detail-value.price.data-v-47f02b22 {
  font-size: 28rpx;
  font-weight: 600;
  color: #7eb662;
}

/* 通用区块 */
.about-section.data-v-47f02b22,
.equipment-section.data-v-47f02b22,
.participants-section.data-v-47f02b22 {
  background-color: #ffffff;
  padding: 30rpx;
  margin-top: 20rpx;
}
.section-title.data-v-47f02b22 {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

/* 活动介绍 */
.about-text.data-v-47f02b22 {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

/* 装备要求 */
.equipment-list.data-v-47f02b22 {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.equipment-item.data-v-47f02b22 {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.equipment-check.data-v-47f02b22 {
  font-size: 24rpx;
  color: #7eb662;
}
.equipment-name.data-v-47f02b22 {
  font-size: 26rpx;
  color: #666;
}

/* 参与者 */
.section-header.data-v-47f02b22 {
  margin-bottom: 20rpx;
}
.participants-list.data-v-47f02b22 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.participant-item.data-v-47f02b22 {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.participant-avatar.data-v-47f02b22 {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.participant-info.data-v-47f02b22 {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.participant-name.data-v-47f02b22 {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}
.participant-level.data-v-47f02b22 {
  font-size: 22rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar.data-v-47f02b22 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top: 2rpx solid #eee;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 30rpx;
  z-index: 100;
}
.price-info.data-v-47f02b22 {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.price-label.data-v-47f02b22 {
  font-size: 22rpx;
  color: #999;
}
.price-value.data-v-47f02b22 {
  font-size: 36rpx;
  font-weight: bold;
  color: #7eb662;
}
.bottom-btn.data-v-47f02b22 {
  flex: 1;
  padding: 28rpx;
  background: linear-gradient(to right, #7eb662, #6a9b54);
  border-radius: 16rpx;
  text-align: center;
}
.bottom-btn-text.data-v-47f02b22 {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}
.safe-area-bottom.data-v-47f02b22 {
  height: env(safe-area-inset-bottom);
}
