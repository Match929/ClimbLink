
.container.data-v-a6dfa7bd {
  min-height: 100vh;
  background-color: #f5f9f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.header.data-v-a6dfa7bd {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  z-index: 100;
}
.back-btn.data-v-a6dfa7bd,
.more-btn.data-v-a6dfa7bd {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
}
.back-icon.data-v-a6dfa7bd {
  font-size: 40rpx;
  color: #333;
}
.more-btn text.data-v-a6dfa7bd {
  font-size: 40rpx;
  color: #333;
}
.empty-spacer.data-v-a6dfa7bd {
  width: 80rpx;
}
.content.data-v-a6dfa7bd {
  flex: 1;
  margin-bottom: 180rpx;
}

/* 商品图片 */
.item-image.data-v-a6dfa7bd {
  width: 100%;
  height: 600rpx;
}

/* 商品信息 */
.item-info.data-v-a6dfa7bd {
  padding: 30rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}
.price-row.data-v-a6dfa7bd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.item-price.data-v-a6dfa7bd {
  font-size: 48rpx;
  font-weight: bold;
  color: #7eb662;
}
.item-status.data-v-a6dfa7bd {
  padding: 8rpx 16rpx;
  background-color: #e8f5e0;
  color: #5a8a3f;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.item-title.data-v-a6dfa7bd {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.item-meta.data-v-a6dfa7bd {
  display: flex;
  gap: 20rpx;
}
.item-location.data-v-a6dfa7bd,
.item-date.data-v-a6dfa7bd {
  font-size: 24rpx;
  color: #999;
}

/* 卖家信息 */
.seller-section.data-v-a6dfa7bd {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.seller-info.data-v-a6dfa7bd {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.seller-avatar.data-v-a6dfa7bd {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.seller-details.data-v-a6dfa7bd {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.seller-name.data-v-a6dfa7bd {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}
.seller-level.data-v-a6dfa7bd {
  font-size: 22rpx;
  color: #999;
}
.message-btn.data-v-a6dfa7bd {
  padding: 16rpx 30rpx;
  border: 2rpx solid #7eb662;
  border-radius: 30rpx;
}
.message-btn text.data-v-a6dfa7bd {
  font-size: 24rpx;
  color: #7eb662;
  font-weight: 500;
}

/* 描述和规格 */
.description-section.data-v-a6dfa7bd,
.specs-section.data-v-a6dfa7bd {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.section-title.data-v-a6dfa7bd {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}
.description-text.data-v-a6dfa7bd {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
.specs-list.data-v-a6dfa7bd {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.spec-item.data-v-a6dfa7bd {
  display: flex;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.spec-item.data-v-a6dfa7bd:last-child {
  border-bottom: none;
}
.spec-label.data-v-a6dfa7bd {
  font-size: 24rpx;
  color: #999;
}
.spec-value.data-v-a6dfa7bd {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 底部操作栏 */
.bottom-bar.data-v-a6dfa7bd {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 2rpx solid #eee;
}
.action-btn.data-v-a6dfa7bd {
  flex: 1;
  padding: 28rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
}
.action-btn text.data-v-a6dfa7bd {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.primary-btn.data-v-a6dfa7bd {
  flex: 2;
  padding: 28rpx;
  background-color: #7eb662;
  border-radius: 16rpx;
  text-align: center;
}
.primary-btn text.data-v-a6dfa7bd {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}
.safe-area-bottom.data-v-a6dfa7bd {
  height: env(safe-area-inset-bottom);
}
