  color: #111827;
}

/* Smart Match Toggle */
.smart-match-section.data-v-d1dfe639 {
  padding: 16px;
}
.smart-match-btn.data-v-d1dfe639 {
  width: 100%;
  padding: 16px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
  box-sizing: border-box;
}
.smart-match-btn.active.data-v-d1dfe639 {
  background: linear-gradient(135deg, #a855f7, #9333ea);
}
.smart-match-left.data-v-d1dfe639 {
  display: flex;
  align-items: center;
  gap: 12px;
}
.smart-match-icon-box.data-v-d1dfe639 {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #f3e8ff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.smart-match-icon-box.active.data-v-d1dfe639 {
  background: rgba(255, 255, 255, 0.2);
}
.smart-match-icon.data-v-d1dfe639 {
  font-size: 20px;
}
.smart-match-texts.data-v-d1dfe639 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.smart-match-title.data-v-d1dfe639 {
  font-size: 16px;
  font-weight: bold;
  color: #111827;
}
.smart-match-btn.active .smart-match-title.data-v-d1dfe639 {
