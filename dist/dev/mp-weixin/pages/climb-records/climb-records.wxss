  max-width: 500px;
  width: 100%;
}
.tabs.data-v-84b51522 {
  background: white;
  border-radius: 16px;
  padding: 6px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}
.tab.data-v-84b51522 {
  padding: 10px 0;
  border-radius: 12px;
  text-align: center;
  transition: all 0.2s;
}
.tab.active.data-v-84b51522 {
  background: #7eb662;
  box-shadow: 0 1px 4px rgba(126, 182, 98, 0.2);
}
.tab-text.data-v-84b51522 {
