  align-items: center;
  justify-content: center;
}
.header-icon.data-v-d1dfe639 {
  font-size: 24px;
}
.venue-indicator.data-v-d1dfe639 {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.2);
  padding: 8px 12px;
  border-radius: 20px;
  margin-bottom: 16px;
  width: -moz-fit-content;
