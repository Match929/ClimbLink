
.container.data-v-d665bec2 {
  min-height: 100vh;
  background-color: #f5f9f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.header.data-v-d665bec2 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
  overflow: hidden;
}
.back-btn.data-v-d665bec2 {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon.data-v-d665bec2 {
  font-size: 40rpx;
  color: #333;
}
.header-title.data-v-d665bec2 {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.post-btn.data-v-d665bec2 {
  padding: 12rpx 28rpx;
  background-color: #7eb662;
  border-radius: 30rpx;
}
.post-btn text.data-v-d665bec2 {
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}
.content.data-v-d665bec2 {
  flex: 1;
}

/* 图片上传 */
.upload-section.data-v-d665bec2 {
  padding: 40rpx 30rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}
.upload-placeholder.data-v-d665bec2 {
  width: 100%;
  height: 300rpx;
  background-color: #f5f9f5;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: 2rpx dashed #d4e7c5;
}
.upload-icon.data-v-d665bec2 {
  font-size: 60rpx;
}
.upload-text.data-v-d665bec2 {
  font-size: 26rpx;
  color: #7eb662;
}

/* 表单 */
.form-section.data-v-d665bec2 {
  background-color: #ffffff;
  padding: 30rpx;
}
.form-group.data-v-d665bec2 {
  margin-bottom: 40rpx;
}
.form-group.data-v-d665bec2:last-child {
  margin-bottom: 0;
}
.form-label.data-v-d665bec2 {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.form-input.data-v-d665bec2 {
  width: 100%;
  padding: 24rpx;
  background-color: #f5f9f5;
  border-radius: 16rpx;
  font-size: 28rpx;
}
.form-textarea.data-v-d665bec2 {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background-color: #f5f9f5;
  border-radius: 16rpx;
  font-size: 28rpx;
}
.picker-display.data-v-d665bec2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #f5f9f5;
  border-radius: 16rpx;
}
.picker-display text.data-v-d665bec2:first-child {
  font-size: 28rpx;
  color: #666;
}
.picker-display text.data-v-d665bec2:last-child {
  font-size: 32rpx;
  color: #999;
}
.type-options.data-v-d665bec2 {
  display: flex;
  gap: 20rpx;
}
.type-option.data-v-d665bec2 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  background-color: #f5f9f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}
.type-option.active.data-v-d665bec2 {
  background-color: #e8f5e0;
  border-color: #7eb662;
}
.type-option text.data-v-d665bec2:first-child {
  font-size: 36rpx;
}
.type-option text.data-v-d665bec2:last-child {
  font-size: 22rpx;
  color: #666;
}
.type-option.active text.data-v-d665bec2:last-child {
  color: #5a8a3f;
  font-weight: 500;
}
.safe-area-bottom.data-v-d665bec2 {
  height: env(safe-area-inset-bottom);
}
